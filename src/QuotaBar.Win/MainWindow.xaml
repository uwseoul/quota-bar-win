<Window x:Class="QuotaBar.Win.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuotaBar.Win"
        xmlns:views="clr-namespace:QuotaBar.Win.Views"
        mc:Ignorable="d"
        Title="Quota Bar"
        Icon="Assets/traffic_light.png"
        Width="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        SizeToContent="Height"
        ResizeMode="NoResize">
    <Border x:Name="MainBorder"
            CornerRadius="12"
            Padding="16"
            BorderBrush="#FF3D3D3D"
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF1A1A2E" Offset="0"/>
                <GradientStop Color="#FF16213E" Offset="0.5"/>
                <GradientStop Color="#FF0F3460" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <StackPanel>
            <!-- Close Button (top right) -->
            <Button x:Name="CloseButton"
                    Content="✕"
                    Foreground="White"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Padding="4"
                    Click="CloseButton_Click"
                    Cursor="Hand"
                    Margin="0,-8,-8,0"/>

            <!-- Header -->
            <Grid x:Name="HeaderGrid" Margin="0,0,0,8">
                <TextBlock Text="Quota Bar"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel x:Name="WindowOptionsPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <ToggleButton x:Name="AlwaysOnTopToggle"
                                  Content="📌"
                                  Style="{StaticResource PinToggleStyle}"
                                  Click="AlwaysOnTopToggle_Click"
                                  ToolTip="Always on Top"
                                  Margin="0,0,8,0"/>
                    <Button x:Name="MinimizeButton"
                            Content="🗕"
                            Style="{StaticResource ModeToggleStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize"
                            Margin="0,0,8,0"/>
                    <Button x:Name="ModeToggleButton"
                            Content="🚥"
                            Style="{StaticResource ModeToggleStyle}"
                            Click="ToggleMode_Click"
                            ToolTip="Toggle View Mode"
                            Margin="0,0,8,0"/>
                    <Button Content="🔄"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            FontSize="14"
                            Click="Refresh_Click"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Content Cards (Detail Mode) -->
            <ScrollViewer x:Name="DetailScroll"
                          MaxHeight="400"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="CardsPanel"/>
            </ScrollViewer>

            <!-- Simple Mode Panel -->
            <StackPanel x:Name="SimplePanel"
                        Visibility="Collapsed">
                <ItemsControl x:Name="SimpleItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Speed indicator dot (always shown) -->
                                <Ellipse Grid.Column="0"
                                         Width="10"
                                         Height="10"
                                         Fill="{Binding Color}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Platform}"
                                           Foreground="White"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                                <!-- Graph bar (visible when Style=Graph) -->
                                <ProgressBar Grid.Column="2"
                                             Value="{Binding PercentValue}"
                                             Maximum="100"
                                             Width="60"
                                             Height="8"
                                             Foreground="{Binding Color}"
                                             Background="#33FFFFFF"
                                             VerticalAlignment="Center"
                                             Margin="4,0"
                                             Visibility="{Binding GraphVisible}"/>
                                <!-- Percent text (visible when Style!=Speed) -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding PercentText}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding PercentVisible}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Compact Mode Panel (single horizontal row, macOS menu-bar style) -->
            <StackPanel x:Name="CompactPanel"
                        Orientation="Horizontal"
                        Visibility="Collapsed">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              MaxWidth="260">
                    <ItemsControl x:Name="CompactItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding BlockWidth}"
                                      Height="18"
                                      Margin="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Short label (Percent / Graph styles) -->
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding ShortLabel}"
                                               Foreground="#CCFFFFFF"
                                               FontSize="6"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Visibility="{Binding LabelVisible}"/>
                                    <!-- Percent value (Percent style) -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding PercentText}"
                                               Foreground="White"
                                               FontSize="8"
                                               FontWeight="Medium"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding PercentVisible}"/>
                                    <!-- Horizontal progress bar (Graph style) -->
                                    <ProgressBar Grid.Row="1"
                                                 Value="{Binding PercentValue}"
                                                 Maximum="100"
                                                 Width="20"
                                                 Height="3"
                                                 Foreground="{Binding Color}"
                                                 Background="#33FFFFFF"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Visibility="{Binding GraphVisible}"/>
                                    <!-- Speed indicator dot (Speed style) -->
                                    <Ellipse Grid.Row="0"
                                             Grid.RowSpan="2"
                                             Width="8"
                                             Height="8"
                                             Fill="{Binding Color}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding DotVisible}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <!-- Compact mode controls (so the user is never trapped) -->
                <Button x:Name="CompactToggle"
                        Content="🚥"
                        Style="{StaticResource ModeToggleStyle}"
                        Click="ToggleMode_Click"
                        ToolTip="Toggle View Mode"
                        FontSize="10"
                        Padding="2,1"
                        Margin="2,0,0,0"/>
                <Button x:Name="CompactClose"
                        Content="✕"
                        Foreground="#99FFFFFF"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="10"
                        Padding="2,1"
                        Click="CloseButton_Click"
                        Cursor="Hand"/>
            </StackPanel>

            <!-- Footer -->
            <StackPanel x:Name="FooterPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0">
                <Button Content="Settings..."
                        Style="{StaticResource FooterButtonStyle}"
                        Click="Settings_Click"/>
                <Button Content="Check for Updates"
                        Style="{StaticResource FooterButtonStyle}"
                        Click="Updates_Click"
                        Margin="8,0"/>
                <Button Content="Quit"
                        Style="{StaticResource FooterButtonStyle}"
                        Click="Quit_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
