<Window x:Class="QuotaBar.Win.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Width="320"
        Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize">
    <Border Background="#FF2D2D2D"
            CornerRadius="12"
            Padding="16"
            BorderBrush="#FF3D3D3D"
            BorderThickness="1">
        <StackPanel>
            <!-- Close Button -->
            <Button Content="✕"
                    Foreground="White"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Padding="4"
                    Click="CloseButton_Click"
                    Cursor="Hand"
                    Margin="0,-8,-8,0"/>

            <TextBlock Text="Settings"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          MaxHeight="340">
                <StackPanel Margin="0,0,0,16">
                    <!-- Account API -->
                    <TextBlock Text="Account API"
                               Foreground="#99FFFFFF"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,8,0,4"/>
                    <TextBlock Text="GLM Platform"
                               Foreground="White"
                               FontSize="11"
                               Margin="0,2"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <RadioButton x:Name="GlmZaiRadio"
                                     Content="z.ai"
                                     Foreground="White"
                                     Margin="0,0,8,0"
                                     Checked="GlmPlatform_Checked"/>
                        <RadioButton x:Name="GlmBigmodelRadio"
                                     Content="bigmodel.cn"
                                     Foreground="White"
                                     Checked="GlmPlatform_Checked"/>
                    </StackPanel>
                    <TextBlock Text="GLM API Key"
                               Foreground="White"
                               FontSize="11"
                               Margin="0,4,0,2"/>
                    <TextBox x:Name="GlmApiKeyBox"
                             Background="#FF1A1A1A"
                             Foreground="White"
                             BorderBrush="#FF3D3D3D"
                             Padding="4"
                             FontSize="11"/>

                    <TextBlock Text="MiniMax API Key"
                               Foreground="White"
                               FontSize="11"
                               Margin="8,8,0,2"/>
                    <TextBox x:Name="MiniMaxApiKeyBox"
                             Background="#FF1A1A1A"
                             Foreground="White"
                             BorderBrush="#FF3D3D3D"
                             Padding="4"
                             FontSize="11"/>

                    <TextBlock Text="OpenCode Go Workspace ID"
                               Foreground="White"
                               FontSize="11"
                               Margin="8,8,0,2"/>
                    <TextBox x:Name="OpenCodeGoWorkspaceBox"
                             Background="#FF1A1A1A"
                             Foreground="White"
                             BorderBrush="#FF3D3D3D"
                             Padding="4"
                             FontSize="11"/>

                    <TextBlock Text="OpenCode Go Auth Cookie"
                               Foreground="White"
                               FontSize="11"
                               Margin="8,8,0,2"/>
                    <TextBox x:Name="OpenCodeGoCookieBox"
                             Background="#FF1A1A1A"
                             Foreground="White"
                             BorderBrush="#FF3D3D3D"
                             Padding="4"
                             FontSize="11"/>

                    <TextBlock Text="Codex (optional, overrides ~/.codex/auth.json)"
                               Foreground="#99FFFFFF"
                               FontSize="10"
                               Margin="0,6,0,2"/>
                    <TextBlock Text="Codex Auth Token"
                               Foreground="White"
                               FontSize="11"
                               Margin="0,2"/>
                    <TextBox x:Name="CodexTokenBox"
                             Background="#FF1A1A1A"
                             Foreground="White"
                             BorderBrush="#FF3D3D3D"
                             Padding="4"
                             FontSize="11"/>
                    <TextBlock Text="Codex Account ID"
                               Foreground="White"
                               FontSize="11"
                               Margin="0,4,0,2"/>
                    <TextBox x:Name="CodexAccountIdBox"
                             Background="#FF1A1A1A"
                             Foreground="White"
                             BorderBrush="#FF3D3D3D"
                             Padding="4"
                             FontSize="11"/>

                    <!-- Platforms -->
                    <TextBlock Text="Platforms"
                               Foreground="#99FFFFFF"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,12,0,4"/>
                    <CheckBox x:Name="GlmCheck" Content="GLM" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="MiniMaxCheck" Content="MiniMax" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CodexCheck" Content="Codex" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="OpenCodeGoCheck" Content="OpenCode Go" Foreground="White" Margin="0,2"/>

                    <!-- Menu Bar Display -->
                    <TextBlock Text="Menu Bar Display"
                               Foreground="#99FFFFFF"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,12,0,4"/>
                    <TextBlock Text="View Mode"
                               Foreground="White"
                               FontSize="11"
                               Margin="0,2"/>
                    <ComboBox x:Name="ViewModeCombo"
                              Background="#FF1A1A1A"
                              Foreground="White"
                              BorderBrush="#FF3D3D3D"
                              Margin="0,2"/>
                    <TextBlock Text="Mode"
                               Foreground="White"
                               FontSize="11"
                               Margin="0,4,0,2"/>
                    <ComboBox x:Name="MenuBarModeCombo"
                              Background="#FF1A1A1A"
                              Foreground="White"
                              BorderBrush="#FF3D3D3D"
                              Margin="0,2"/>
                    <TextBlock Text="Style"
                               Foreground="White"
                               FontSize="11"
                               Margin="0,4,0,2"/>
                    <ComboBox x:Name="DisplayStyleCombo"
                              Background="#FF1A1A1A"
                              Foreground="White"
                              BorderBrush="#FF3D3D3D"
                              Margin="0,2"/>

                    <!-- Appearance -->
                    <TextBlock Text="Appearance"
                               Foreground="#99FFFFFF"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,12,0,4"/>
                    <ComboBox x:Name="ThemeCombo"
                              Background="#FF1A1A1A"
                              Foreground="White"
                              BorderBrush="#FF3D3D3D"
                              Margin="0,2"/>

                    <!-- Refresh Interval -->
                    <TextBlock Text="Refresh"
                               Foreground="#99FFFFFF"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,12,0,4"/>
                    <TextBlock Text="Refresh Interval (seconds)"
                               Foreground="White"
                               FontSize="11"
                               Margin="0,2"/>
                    <TextBox x:Name="RefreshIntervalBox"
                             Background="#FF1A1A1A"
                             Foreground="White"
                             BorderBrush="#FF3D3D3D"
                             Padding="4"
                             FontSize="11"/>

                    <!-- Launch at Login -->
                    <TextBlock Text="System"
                               Foreground="#99FFFFFF"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="0,12,0,4"/>
                    <CheckBox x:Name="LaunchAtLoginCheck" Content="Launch at Login" Foreground="White" Margin="0,2"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Save Button -->
            <Button Content="Save"
                    Background="#FF007AFF"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="8,4"
                    FontSize="12"
                    FontWeight="Bold"
                    HorizontalAlignment="Stretch"
                    Margin="0,12,0,0"
                    Click="Save_Click"
                    Cursor="Hand"/>
        </StackPanel>
    </Border>
</Window>
