<UserControl x:Class="QuotaBar.Win.Views.UsageCardView"
              x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             d:DesignHeight="200" d:DesignWidth="300">
    <StackPanel HorizontalAlignment="Stretch">
        <!-- Platform Header -->
        <TextBlock Text="{Binding PlatformName, ElementName=Root}"
                   Foreground="#99FFFFFF"
                   FontSize="10"
                   FontWeight="Bold"
                   Margin="0,8,0,2"/>

        <!-- Quota Entries -->
        <ItemsControl ItemsSource="{Binding Entries, ElementName=Root}"
                      HorizontalAlignment="Stretch">
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="16,2,0,2"
                          HorizontalAlignment="Stretch">
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="58"/>
                             <ColumnDefinition Width="38"/>
                             <ColumnDefinition Width="46"/>
                         </Grid.ColumnDefinitions>
 
                         <!-- Name -->
                         <TextBlock Grid.Column="0"
                                    Text="{Binding Name}"
                                    Foreground="White"
                                    FontSize="11"
                                    VerticalAlignment="Center"/>
 
                         <!-- Reset Timer -->
                          <TextBlock Grid.Column="1"
                                     Text="{Binding ResetDisplay}"
                                     Foreground="#99FFFFFF"
                                     FontSize="9"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
 
                         <!-- Percent -->
                          <TextBlock Grid.Column="2"
                                     Text="{Binding PercentDisplay}"
                                     Foreground="White"
                                     FontSize="11"
                                     FontWeight="Medium"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"/>
 
                         <!-- Speed Badge -->
                          <StackPanel Grid.Column="3"
                                      Orientation="Horizontal"
                                      Margin="8,0,0,0"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center">
                             <Ellipse Width="5"
                                      Height="5"
                                      Fill="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToColorConverter}}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,2,0"/>
                             <TextBlock Text="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToLabelConverter}}"
                                        Foreground="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToColorConverter}}"
                                        FontSize="9"
                                        VerticalAlignment="Center"/>
                         </StackPanel>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
