<UserControl x:Class="QuotaBar.Win.Views.UsageCardView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="300">
    <StackPanel>
        <!-- Platform Header -->
        <TextBlock Text="{Binding PlatformName, ElementName=Root}"
                   Foreground="#99FFFFFF"
                   FontSize="10"
                   FontWeight="Bold"
                   Margin="0,8,0,2"/>

        <!-- Quota Entries -->
        <ItemsControl ItemsSource="{Binding Entries, ElementName=Root}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="16,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Name -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Name}"
                                   Foreground="White"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>

                        <!-- Speed Badge -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="6,0"
                                    VerticalAlignment="Center">
                            <Ellipse Width="5"
                                     Height="5"
                                     Fill="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToColorConverter}}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,2,0"/>
                            <TextBlock Text="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToLabelConverter}}"
                                       Foreground="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToColorConverter}}"
                                       FontSize="9"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Percent -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding DisplayPercent, StringFormat='{}{0}%'}"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
