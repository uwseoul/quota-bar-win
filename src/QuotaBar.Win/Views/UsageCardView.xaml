<UserControl x:Class="QuotaBar.Win.Views.UsageCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300">
    <Border Background="#0FFFFFFF"
            BorderBrush="#59FFFFFF"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,4">
        <StackPanel>
            <!-- Platform Header -->
            <TextBlock Text="{Binding PlatformName}"
                       Foreground="White"
                       FontSize="12"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

            <!-- Quota Entries -->
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,4">
                            <!-- Name + Badge + Percent -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0">
                                    <Ellipse Width="6" Height="6"
                                             Fill="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToColorConverter}}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,2,0"/>
                                    <TextBlock Text="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToLabelConverter}}"
                                               Foreground="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToColorConverter}}"
                                               FontSize="9"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DisplayPercent, StringFormat='{}{0}%'}"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Progress Bar -->
                            <Grid Height="8" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding UsagePercent, Converter={StaticResource PercentToGridLengthConverter}}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{Binding SpeedStatus, Converter={StaticResource SpeedStatusToColorConverter}}"
                                        CornerRadius="3"/>
                                <Border Grid.Column="1"
                                        Background="#33FFFFFF"
                                        CornerRadius="3"/>
                            </Grid>

                            <!-- Footer: Reset + Usage -->
                            <Grid>
                                <TextBlock Text="{Binding ResetDisplay}"
                                           Foreground="#99FFFFFF"
                                           FontSize="9"
                                           HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding UsageDisplay}"
                                           Foreground="#99FFFFFF"
                                           FontSize="9"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
